# pnpm settings for Expo + pnpm workspace compatibility

# Hoist all packages to the root node_modules.
# Metro's resolver follows nodeModulesPaths, not pnpm's isolated virtual store,
# so hoisted layout is the most reliable for React Native / Expo web bundling.
node-linker=hoisted

# Treat peer-dep version mismatches as warnings, not hard errors.
# Several React Native packages (Skia, Reanimated) have intentionally loose
# peer dep declarations that would otherwise block installs.
strict-peer-dependencies=false
